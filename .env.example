# Server
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prepsmart_lang_cert
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=7d

# MCP Question Server
# Command to launch your MCP server process
MCP_SERVER_COMMAND=node
MCP_SERVER_SCRIPT=./mcp-question-server/dist/index.js
# Or if your MCP server accepts args:
# MCP_SERVER_ARGS=--port 3001
