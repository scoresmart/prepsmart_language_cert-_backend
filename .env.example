# Server
NODE_ENV=development
PORT=5000

# Comma-separated browser origins allowed to call this API (credentials enabled).
# Add your Vercel production URL here when deploying the LC portal.
CORS_ORIGIN=http://localhost:5174,http://localhost:5173,http://localhost:3000,https://prepsmart-language-cert-frontend.vercel.app

# Allow any https://*.vercel.app origin (production + preview deploys). Set to false to disable.
CORS_ALLOW_VERCEL=true

# Allow any https://*.up.railway.app origin. Set to false to disable.
CORS_ALLOW_RAILWAY=true

# In production, also allow http://localhost:* (useful for local dev against Railway). Default: false.
# CORS_ALLOW_LOCALHOST=true

# Supabase (get these from https://supabase.com/dashboard/project/sepzceaicoldqhyxxzff/settings/api)
SUPABASE_URL=https://sepzceaicoldqhyxxzff.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# LC admin login (set via: node scripts/ensure-admin-user.mjs)
# Email: contact@scoresmartpte.com
# Password: SCORE2026

# JWT (same as Supabase JWT Secret — Settings > API > JWT Settings)
JWT_SECRET=your_supabase_jwt_secret_here
JWT_EXPIRES_IN=7d

# Claude (writing + speaking scoring via AI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Azure Speech Services (speaking audio transcription)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=australiaeast
